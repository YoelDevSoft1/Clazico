{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@yoeldevsoft25/storefront-sdk": ["./libs/storefront-sdk/dist/index.js"],
      "@yoeldevsoft25/storefront-sdk/*": ["./libs/storefront-sdk/dist/*"],
      "@yoeldevsoft25/store-contracts": ["./libs/store-contracts/src/index.ts"],
      "@yoeldevsoft25/store-contracts/*": ["./libs/store-contracts/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
